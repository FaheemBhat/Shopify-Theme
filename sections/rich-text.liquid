{% comment %}
  Rich Text Section
  Displays heading and rich text content with customizable styling
{% endcomment %}

<section class="rich-text-section animate-on-scroll animate-fade" data-section-id="{{ section.id }}">
  <div class="rich-text-container">
    <div class="rich-text-content">

      {% if section.settings.eyebrow != blank %}
        <p class="rich-text-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="rich-text-heading{% if section.settings.show_heading_accent %} rich-text-heading--accent{% endif %}">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="rich-text-body">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <div class="rich-text-cta">
          <a
            href="{{ section.settings.button_link }}"
            class="rich-text-btn{% if section.settings.button_style == 'outline' %} rich-text-btn--outline{% endif %}"
            style="
              --rt-btn-bg: {{ section.settings.button_color }};
              --rt-btn-text: {{ section.settings.button_text_color }};
              --rt-btn-radius: {{ section.settings.button_radius }}px;
            "
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}

    </div>
  </div>
</section>

<style>
  .rich-text-section {
    --text-color: {{ section.settings.text_color }};
    --heading-color: {{ section.settings.heading_color }};
    --bg-color: {{ section.settings.background_color }};
    --content-width: {{ section.settings.content_width }}%;
    --text-size: {{ section.settings.text_size }}px;
    --heading-size: {{ section.settings.heading_size }}px;
    --text-align: {{ section.settings.text_alignment }};

    background-color: var(--bg-color);
    padding: {{ section.settings.section_padding }}px 0;
  }

  .rich-text-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .rich-text-content {
    width: var(--content-width);
    max-width: 100%;
    margin: 0 auto;
    text-align: var(--text-align);
  }

  .rich-text-heading {
    font-size: var(--heading-size);
    font-weight: 700;
    color: var(--heading-color);
    margin: 0 0 5px;
    line-height: 1.3;
  }

  .rich-text-body {
    font-size: var(--text-size);
    color: var(--text-color);
    line-height: 1.7;
  }

  .rich-text-body p {
    margin: 0 0 1em;
  }

  .rich-text-body p:last-child {
    margin-bottom: 0;
  }

  .rich-text-body strong,
  .rich-text-body b {
    font-weight: 700;
  }

  .rich-text-body em,
  .rich-text-body i {
    font-style: italic;
  }

  .rich-text-body a {
    color: var(--heading-color);
    text-decoration: underline;
    transition: opacity 0.2s ease;
  }

  .rich-text-body a:hover {
    opacity: 0.7;
  }

  .rich-text-body ul,
  .rich-text-body ol {
    margin: 0 0 1em;
    padding-left: 1.5em;
    {% if section.settings.text_alignment == 'center' %}
      text-align: left;
      display: inline-block;
    {% elsif section.settings.text_alignment == 'right' %}
      text-align: left;
      display: inline-block;
    {% endif %}
  }

  .rich-text-body ul {
    list-style-type: disc;
  }

  .rich-text-body ol {
    list-style-type: decimal;
  }

  .rich-text-body li {
    margin-bottom: 0.5em;
  }

  .rich-text-body li:last-child {
    margin-bottom: 0;
  }

  /* Responsive */
  @media screen and (max-width: 768px) {
    .rich-text-container {
      padding: 0 20px;
    }

    .rich-text-content {
      width: 100%;
    }

    .rich-text-heading {
      font-size: calc(var(--heading-size) * 0.8);
    }

    .rich-text-body {
      font-size: calc(var(--text-size) * 0.95);
    }
  }

  @media screen and (max-width: 480px) {
    .rich-text-container {
      padding: 0 16px;
    }

    .rich-text-heading {
      font-size: calc(var(--heading-size) * 0.7);
      margin-bottom: 16px;
    }
  }

  /* ============================================================
     Phase 4: Rich Text Upgrades
     ============================================================ */

  /* Eyebrow label */
  .rich-text-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--heading-color);
    opacity: 0.6;
    margin: 0 0 14px;
    padding: 5px 14px;
    border: 1.5px solid var(--heading-color);
    border-radius: 100px;
    opacity: 0.65;
  }

  /* Accent underline on heading */
  .rich-text-heading--accent {
    position: relative;
    display: inline-block;
    padding-bottom: 12px;
  }
  .rich-text-heading--accent::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 48px;
    height: 3px;
    background: var(--heading-color);
    border-radius: 2px;
    opacity: 0.4;
  }
  .rich-text-content[style*="text-align: left"] .rich-text-heading--accent::after,
  .rich-text-content[style*="text-align:left"] .rich-text-heading--accent::after {
    left: 0;
    transform: none;
  }
  .rich-text-content[style*="text-align: right"] .rich-text-heading--accent::after,
  .rich-text-content[style*="text-align:right"] .rich-text-heading--accent::after {
    left: auto;
    right: 0;
    transform: none;
  }

  /* CTA button */
  .rich-text-cta {
    margin-top: 28px;
  }
  .rich-text-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 36px;
    background: var(--rt-btn-bg, #1a1a2e);
    color: var(--rt-btn-text, #fff);
    border-radius: var(--rt-btn-radius, 50px);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.03em;
    transition: transform 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
  }
  .rich-text-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    opacity: 0.9;
  }
  .rich-text-btn--outline {
    background: transparent;
    border: 2px solid var(--rt-btn-bg, #1a1a2e);
    color: var(--rt-btn-bg, #1a1a2e);
  }
  .rich-text-btn--outline:hover {
    background: var(--rt-btn-bg, #1a1a2e);
    color: var(--rt-btn-text, #fff);
  }
</style>

{% schema %}
{
  "name": "Rich text",
  "tag": "section",
  "class": "rich-text-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small uppercase label above the heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading_accent",
      "label": "Show accent underline on heading",
      "default": false
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p> text </p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Rich text"
    }
  ]
}
{% endschema %}
