{% comment %}
  Testimonial Section — Phase 6
  Slider with eyebrow, large quote mark, verified badge, avatar initials
{% endcomment %}

<section
  class="testimonial-section animate-on-scroll animate-fade"
  style="
    --ts-bg: {{ section.settings.background_color }};
    --ts-card-bg: {{ section.settings.card_background }};
    --ts-card-border: {{ section.settings.card_border_color }};
    --ts-text: {{ section.settings.text_color }};
    --ts-heading: {{ section.settings.heading_color }};
    --ts-star: {{ section.settings.star_color }};
    --ts-author: {{ section.settings.author_name_color }};
    --ts-accent: {{ section.settings.accent_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  "
>
  <div class="testimonial-container">

    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
      <div class="testimonial-header">
        {% if section.settings.eyebrow != blank %}
          <p class="testimonial-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="testimonial-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="testimonial-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div
        class="testimonial-slider"
        data-autoplay="{{ section.settings.autoplay }}"
        data-interval="{{ section.settings.autoplay_speed | times: 1000 }}"
        data-section-id="{{ section.id }}"
      >
        <div class="testimonial-track">
          {% for block in section.blocks %}
            <article
              class="testimonial-card"
              {{ block.shopify_attributes }}
            >
              {# Decorative quote mark #}
              <div class="testimonial-quote-mark" aria-hidden="true">
                <svg width="36" height="28" viewBox="0 0 36 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 28V17.2C0 12.5333 1.13333 8.66667 3.4 5.6C5.66667 2.53333 9.06667 0.666667 13.6 0L15.2 3.2C12.5333 3.73333 10.4667 4.93333 9 6.8C7.53333 8.66667 6.86667 10.8 7 13.2H14V28H0ZM20.8 28V17.2C20.8 12.5333 21.9333 8.66667 24.2 5.6C26.4667 2.53333 29.8667 0.666667 34.4 0L36 3.2C33.3333 3.73333 31.2667 4.93333 29.8 6.8C28.3333 8.66667 27.6667 10.8 27.8 13.2H34.8V28H20.8Z" fill="currentColor"/>
                </svg>
              </div>

              <div class="testimonial-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                {% for i in (1..5) %}
                  {% if i <= block.settings.rating %}
                    <svg class="ts-star ts-star--filled" width="16" height="16" viewBox="0 0 24 24" fill="var(--ts-star)" stroke="none">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {% else %}
                    <svg class="ts-star ts-star--empty" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ts-star)" stroke-width="1.5">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {% endif %}
                {% endfor %}
              </div>

              {% if block.settings.description != blank %}
                <p class="testimonial-description">{{ block.settings.description }}</p>
              {% endif %}

              <div class="testimonial-author-wrap">
                {% if block.settings.author_image != blank %}
                  <img
                    class="testimonial-author-img"
                    src="{{ block.settings.author_image | image_url: width: 80, height: 80, crop: 'center' }}"
                    alt="{{ block.settings.author_name | escape }}"
                    width="44"
                    height="44"
                    loading="lazy"
                  >
                {% else %}
                  <div class="testimonial-author-initials" aria-hidden="true">
                    {{ block.settings.author_name | slice: 0 | upcase }}
                  </div>
                {% endif %}

                <div class="testimonial-author-info">
                  {% if block.settings.author_name != blank %}
                    <span class="testimonial-author-name">
                      {{ block.settings.author_name }}
                      {% if section.settings.show_verified_badge %}
                        <span class="testimonial-verified" title="Verified purchase">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                      {% endif %}
                    </span>
                  {% endif %}
                  {% if block.settings.author_title != blank %}
                    <span class="testimonial-author-title">{{ block.settings.author_title }}</span>
                  {% endif %}
                </div>
              </div>
            </article>
          {% endfor %}
        </div>
      </div>

      {% if section.blocks.size > 1 %}
        <div class="testimonial-nav">
          <button class="testimonial-nav-btn testimonial-prev" aria-label="Previous testimonial">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <div class="testimonial-dots" role="tablist" aria-label="Testimonial navigation"></div>
          <button class="testimonial-nav-btn testimonial-next" aria-label="Next testimonial">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      {% endif %}
    {% endif %}

  </div>
</section>

<style>
  .testimonial-section {
    background: var(--ts-bg);
    width: 100%;
    overflow: hidden;
  }

  .testimonial-container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  .testimonial-header { text-align: center; margin-bottom: 52px; }

  .testimonial-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ts-accent);
    margin: 0 0 14px;
    padding: 4px 14px;
    border: 1.5px solid var(--ts-accent);
    border-radius: 100px;
    opacity: 0.75;
  }

  .testimonial-heading {
    font-size: clamp(24px, 4vw, {{ section.settings.heading_size }}px);
    font-weight: 700;
    color: var(--ts-heading);
    margin: 0 0 10px;
    line-height: 1.25;
  }

  .testimonial-subheading {
    font-size: 16px;
    color: var(--ts-text);
    opacity: 0.7;
    margin: 0;
    line-height: 1.6;
  }

  /* Slider */
  .testimonial-slider {
    position: relative;
    overflow: hidden;
  }

  .testimonial-track {
    display: flex;
    gap: 24px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Cards */
  .testimonial-card {
    flex: 0 0 calc(33.333% - 16px);
    min-width: 280px;
    padding: 32px;
    border-radius: 16px;
    border: 1px solid var(--ts-card-border);
    background: var(--ts-card-bg);
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  /* Decorative quote */
  .testimonial-quote-mark {
    color: var(--ts-accent);
    opacity: 0.12;
    margin-bottom: -4px;
  }

  /* Stars */
  .testimonial-stars { display: flex; gap: 3px; }
  .ts-star { flex-shrink: 0; }

  /* Description */
  .testimonial-description {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.72;
    color: var(--ts-text);
    margin: 0;
    flex: 1;
  }

  /* Author */
  .testimonial-author-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 4px;
    border-top: 1px solid var(--ts-card-border);
    margin-top: 4px;
  }

  .testimonial-author-img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonial-author-initials {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--ts-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .testimonial-author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .testimonial-author-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--ts-author);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .testimonial-verified {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--ts-accent);
    color: #fff;
    flex-shrink: 0;
  }

  .testimonial-author-title {
    font-size: 12px;
    color: var(--ts-text);
    opacity: 0.6;
  }

  /* Nav */
  .testimonial-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 36px;
  }

  .testimonial-nav-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid var(--ts-card-border);
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ts-heading);
    transition: background 0.22s, border-color 0.22s, color 0.22s, transform 0.22s;
    flex-shrink: 0;
  }

  .testimonial-nav-btn:hover {
    background: var(--ts-accent);
    border-color: var(--ts-accent);
    color: #fff;
    transform: translateY(-2px);
  }

  /* Dots */
  .testimonial-dots { display: flex; gap: 8px; align-items: center; }

  .ts-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ts-card-border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .ts-dot--active {
    background: var(--ts-accent);
    transform: scale(1.35);
  }

  /* Responsive */
  @media screen and (max-width: 992px) {
    .testimonial-card { flex: 0 0 calc(50% - 12px); }
  }

  @media screen and (max-width: 640px) {
    .testimonial-card {
      flex: 0 0 85%;
      padding: 24px;
    }
    .testimonial-card:hover { transform: none; }
    .testimonial-header { margin-bottom: 32px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-track,
    .testimonial-card,
    .testimonial-nav-btn { transition: none; }
  }
</style>

<script>
(function () {
  function initTestimonialSlider(root) {
    var section = (root === document ? root : root).querySelector
      ? (root === document ? document : root).querySelector('.testimonial-slider')
      : null;
    if (!section) {
      section = (root && root.classList && root.classList.contains('testimonial-slider')) ? root : null;
      if (!section) section = root && root.querySelector ? root.querySelector('.testimonial-slider') : null;
    }
    if (!section) return;

    var track = section.querySelector('.testimonial-track');
    if (!track) return;

    var cards = track.querySelectorAll('.testimonial-card');
    if (cards.length < 2) return;

    var container = section.closest('.testimonial-section') || document;
    var prevBtn = container.querySelector ? container.querySelector('.testimonial-prev') : null;
    var nextBtn = container.querySelector ? container.querySelector('.testimonial-next') : null;
    var dotsWrap = container.querySelector ? container.querySelector('.testimonial-dots') : null;

    var autoplay = section.dataset.autoplay === 'true';
    var interval = parseInt(section.dataset.interval) || 4000;
    var current = 0;
    var timer = null;
    var total = cards.length;

    function getVisible() {
      var w = window.innerWidth;
      if (w <= 640) return 1;
      if (w <= 992) return 2;
      return 3;
    }

    function getMax() { return Math.max(0, total - getVisible()); }

    function getOffset() {
      if (!cards[0]) return 0;
      var gap = parseInt(window.getComputedStyle(track).gap) || 24;
      return cards[0].offsetWidth + gap;
    }

    function render() {
      track.style.transform = 'translateX(-' + current * getOffset() + 'px)';
      if (dotsWrap) {
        dotsWrap.querySelectorAll('.ts-dot').forEach(function (d, i) {
          d.classList.toggle('ts-dot--active', i === current);
          d.setAttribute('aria-selected', i === current ? 'true' : 'false');
        });
      }
    }

    function clamp() {
      var max = getMax();
      if (current > max) current = max;
    }

    function goTo(i) {
      var max = getMax();
      current = Math.max(0, Math.min(i, max));
      render();
    }

    function next() { goTo(current + 1 > getMax() ? 0 : current + 1); }
    function prev() { goTo(current - 1 < 0 ? getMax() : current - 1); }

    function startTimer() {
      stopTimer();
      if (autoplay && getMax() > 0) timer = setInterval(next, interval);
    }

    function stopTimer() { if (timer) { clearInterval(timer); timer = null; } }

    /* Build dots */
    if (dotsWrap) {
      for (var d = 0; d < total; d++) {
        (function (idx) {
          var dot = document.createElement('button');
          dot.className = 'ts-dot' + (idx === 0 ? ' ts-dot--active' : '');
          dot.setAttribute('role', 'tab');
          dot.setAttribute('aria-label', 'Go to testimonial ' + (idx + 1));
          dot.setAttribute('aria-selected', idx === 0 ? 'true' : 'false');
          dot.addEventListener('click', function () { goTo(idx); stopTimer(); startTimer(); });
          dotsWrap.appendChild(dot);
        })(d);
      }
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { prev(); stopTimer(); startTimer(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { next(); stopTimer(); startTimer(); });

    section.addEventListener('mouseenter', stopTimer);
    section.addEventListener('mouseleave', startTimer);

    window.addEventListener('resize', function () { clamp(); render(); });

    render();
    startTimer();
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.testimonial-section').forEach(function (s) {
      initTestimonialSlider(s);
    });
  });

  document.addEventListener('shopify:section:load', function (e) {
    initTestimonialSlider(e.target);
  });
})();
</script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "testimonial-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small pill label above the heading"
