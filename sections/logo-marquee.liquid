{% comment %}
  Logo Marquee Section — Phase 6
  Continuous scrolling brand logos, fade edges, pause on hover
{% endcomment %}

{% if section.blocks.size > 0 %}
<section
  class="lm-section animate-on-scroll animate-fade"
  data-section-id="{{ section.id }}"
  style="
    --lm-bg: {{ section.settings.background_color }};
    --lm-logo-h: {{ section.settings.logo_height }}px;
    --lm-dur: {{ section.settings.scroll_speed }}s;
    --lm-opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
    --lm-gap: {{ section.settings.logo_gap }}px;
  "
>
  {% if section.settings.heading != blank %}
    <p class="lm-heading">{{ section.settings.heading }}</p>
  {% endif %}

  <div class="lm-track-wrap">
    <div
      class="lm-track{% if section.settings.pause_on_hover %} lm-track--pausable{% endif %}"
      aria-label="Partner and brand logos"
    >
      <div class="lm-inner" aria-hidden="false">
        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <div class="lm-item" {{ block.shopify_attributes }}>
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="lm-logo-link" rel="noopener" tabindex="0">
              {% endif %}
              {% if block.settings.image != blank %}
                <img
                  class="lm-logo{% if section.settings.grayscale %} lm-logo--grayscale{% endif %}"
                  src="{{ block.settings.image | image_url: height: 120 }}"
                  alt="{{ block.settings.alt_text | default: block.settings.image.alt | default: 'Brand logo' | escape }}"
                  width="{{ block.settings.image.width | default: 160 }}"
                  height="{{ block.settings.image.height | default: 60 }}"
                  loading="lazy"
                >
              {% else %}
                <div class="lm-logo lm-logo--placeholder">
                  <svg width="80" height="32" viewBox="0 0 80 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="80" height="32" rx="6" fill="currentColor" opacity="0.12"/>
                    <rect x="10" y="12" width="60" height="8" rx="3" fill="currentColor" opacity="0.25"/>
                  </svg>
                </div>
              {% endif %}
              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {# Duplicate for seamless infinite loop #}
      <div class="lm-inner" aria-hidden="true">
        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <div class="lm-item">
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="lm-logo-link" tabindex="-1">
              {% endif %}
              {% if block.settings.image != blank %}
                <img
                  class="lm-logo{% if section.settings.grayscale %} lm-logo--grayscale{% endif %}"
                  src="{{ block.settings.image | image_url: height: 120 }}"
                  alt=""
                  width="{{ block.settings.image.width | default: 160 }}"
                  height="{{ block.settings.image.height | default: 60 }}"
                  loading="lazy"
                >
              {% else %}
                <div class="lm-logo lm-logo--placeholder">
                  <svg width="80" height="32" viewBox="0 0 80 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="80" height="32" rx="6" fill="currentColor" opacity="0.12"/>
                    <rect x="10" y="12" width="60" height="8" rx="3" fill="currentColor" opacity="0.25"/>
                  </svg>
                </div>
              {% endif %}
              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% endif %}

<style>
  .lm-section {
    background-color: var(--lm-bg);
    padding: {{ section.settings.section_padding }}px 0;
    overflow: hidden;
  }

  .lm-heading {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: currentColor;
    opacity: 0.4;
    margin: 0 0 28px;
  }

  /* Fade edge mask */
  .lm-track-wrap {
    position: relative;
    overflow: hidden;
    {% if section.settings.fade_edges %}
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    {% endif %}
  }

  .lm-track {
    display: flex;
    width: max-content;
    animation: lmScroll var(--lm-dur, 30s) linear infinite;
  }

  .lm-track--pausable:hover {
    animation-play-state: paused;
  }

  @keyframes lmScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .lm-inner {
    display: flex;
    align-items: center;
    gap: var(--lm-gap, 56px);
    padding: 0 calc(var(--lm-gap, 56px) / 2);
    flex-shrink: 0;
  }

  .lm-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .lm-logo-link {
    display: flex;
    align-items: center;
    outline-offset: 4px;
  }

  .lm-logo {
    height: var(--lm-logo-h, 40px);
    width: auto;
    max-width: 160px;
    object-fit: contain;
    opacity: var(--lm-opacity, 0.6);
    transition: opacity 0.25s ease, filter 0.25s ease;
    display: block;
  }

  .lm-logo--grayscale {
    filter: grayscale(100%);
  }

  .lm-logo:hover,
  .lm-logo-link:hover .lm-logo {
    opacity: 1;
    filter: none;
  }

  .lm-logo--placeholder {
    height: var(--lm-logo-h, 40px);
    display: flex;
    align-items: center;
    color: currentColor;
  }

  @media (prefers-reduced-motion: reduce) {
    .lm-track { animation: none; }
  }
</style>

{% schema %}
{
  "name": "Logo Marquee",
  "tag": "section",
  "class": "lm-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Label text",
      "info": "Small uppercase label above logos — e.g. \"Trusted by leading brands\"",
      "default": "Trusted by leading brands"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Lower = faster scroll"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "fade_edges",
      "label": "Fade edges",
      "default": true,
      "info": "Soft transparency at left and right edges"
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Grayscale logos",
      "default": true,
      "info": "Converts logos to greyscale; color on hover"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "Logo opacity",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "range",
      "id": "logo_gap",
      "label": "Gap between logos",
      "min": 24,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 16,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f8f8"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "Describe the brand for screen readers"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Logo Marquee",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
