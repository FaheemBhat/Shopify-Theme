{% comment %}
  Comparison Table Section — Phase 6
  3-tier feature comparison with checkmarks, highlighted column, CTA row
{% endcomment %}

<section
  class="ct-section animate-on-scroll animate-fade"
  data-section-id="{{ section.id }}"
  style="
    --ct-bg: {{ section.settings.background_color }};
    --ct-text: {{ section.settings.text_color }};
    --ct-heading: {{ section.settings.heading_color }};
    --ct-border: {{ section.settings.border_color }};
    --ct-accent: {{ section.settings.accent_color }};
    --ct-yes: {{ section.settings.check_color }};
    --ct-no: {{ section.settings.cross_color }};
    --ct-popular-bg: {{ section.settings.popular_bg }};
    --ct-popular-text: {{ section.settings.popular_text_color }};
  "
>
  <div class="ct-container">

    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
      <div class="ct-header">
        {% if section.settings.eyebrow != blank %}
          <p class="ct-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="ct-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="ct-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ct-table-wrap">
      <table class="ct-table" role="table">
        <thead>
          <tr class="ct-tier-row">
            <th class="ct-feature-label-head" scope="col"></th>

            {%- assign tier1_popular = section.settings.popular_tier == '1' -%}
            {%- assign tier2_popular = section.settings.popular_tier == '2' -%}
            {%- assign tier3_popular = section.settings.popular_tier == '3' -%}

            <th class="ct-tier-head{% if tier1_popular %} ct-tier-head--popular{% endif %}" scope="col">
              {% if tier1_popular and section.settings.popular_label != blank %}
                <div class="ct-popular-badge">{{ section.settings.popular_label }}</div>
              {% endif %}
              <div class="ct-tier-name">{{ section.settings.tier1_name | default: 'Starter' }}</div>
              <div class="ct-tier-price">{{ section.settings.tier1_price }}</div>
              {% if section.settings.tier1_cta_text != blank %}
                <a
                  href="{{ section.settings.tier1_cta_link | default: '#' }}"
                  class="ct-cta-btn{% if tier1_popular %} ct-cta-btn--popular{% endif %}"
                >{{ section.settings.tier1_cta_text }}</a>
              {% endif %}
            </th>

            <th class="ct-tier-head{% if tier2_popular %} ct-tier-head--popular{% endif %}" scope="col">
              {% if tier2_popular and section.settings.popular_label != blank %}
                <div class="ct-popular-badge">{{ section.settings.popular_label }}</div>
              {% endif %}
              <div class="ct-tier-name">{{ section.settings.tier2_name | default: 'Pro' }}</div>
              <div class="ct-tier-price">{{ section.settings.tier2_price }}</div>
              {% if section.settings.tier2_cta_text != blank %}
                <a
                  href="{{ section.settings.tier2_cta_link | default: '#' }}"
                  class="ct-cta-btn{% if tier2_popular %} ct-cta-btn--popular{% endif %}"
                >{{ section.settings.tier2_cta_text }}</a>
              {% endif %}
            </th>

            <th class="ct-tier-head{% if tier3_popular %} ct-tier-head--popular{% endif %}" scope="col">
              {% if tier3_popular and section.settings.popular_label != blank %}
                <div class="ct-popular-badge">{{ section.settings.popular_label }}</div>
              {% endif %}
              <div class="ct-tier-name">{{ section.settings.tier3_name | default: 'Enterprise' }}</div>
              <div class="ct-tier-price">{{ section.settings.tier3_price }}</div>
              {% if section.settings.tier3_cta_text != blank %}
                <a
                  href="{{ section.settings.tier3_cta_link | default: '#' }}"
                  class="ct-cta-btn{% if tier3_popular %} ct-cta-btn--popular{% endif %}"
                >{{ section.settings.tier3_cta_text }}</a>
              {% endif %}
            </th>
          </tr>
        </thead>

        <tbody>
          {% for block in section.blocks %}
            {% if block.type == 'feature_row' %}
              <tr class="ct-row" {{ block.shopify_attributes }}>
                <td class="ct-feature-label">
                  {{ block.settings.feature_name }}
                  {% if block.settings.feature_note != blank %}
                    <span class="ct-feature-note">{{ block.settings.feature_note }}</span>
                  {% endif %}
                </td>

                <td class="ct-cell{% if tier1_popular %} ct-cell--popular{% endif %}">
                  {%- assign v1 = block.settings.tier1_value -%}
                  {%- if v1 == 'yes' -%}
                    <span class="ct-check" aria-label="Included">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                  {%- elsif v1 == 'no' -%}
                    <span class="ct-cross" aria-label="Not included">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </span>
                  {%- else -%}
                    <span class="ct-value">{{ v1 }}</span>
                  {%- endif -%}
                </td>

                <td class="ct-cell{% if tier2_popular %} ct-cell--popular{% endif %}">
                  {%- assign v2 = block.settings.tier2_value -%}
                  {%- if v2 == 'yes' -%}
                    <span class="ct-check" aria-label="Included">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                  {%- elsif v2 == 'no' -%}
                    <span class="ct-cross" aria-label="Not included">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </span>
                  {%- else -%}
                    <span class="ct-value">{{ v2 }}</span>
                  {%- endif -%}
                </td>

                <td class="ct-cell{% if tier3_popular %} ct-cell--popular{% endif %}">
                  {%- assign v3 = block.settings.tier3_value -%}
                  {%- if v3 == 'yes' -%}
                    <span class="ct-check" aria-label="Included">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                  {%- elsif v3 == 'no' -%}
                    <span class="ct-cross" aria-label="Not included">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </span>
                  {%- else -%}
                    <span class="ct-value">{{ v3 }}</span>
                  {%- endif -%}
                </td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>

  </div>
</section>

<style>
  .ct-section {
    background-color: var(--ct-bg);
    padding: {{ section.settings.section_padding }}px 0;
  }

  .ct-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  .ct-header { text-align: center; margin-bottom: 52px; }

  .ct-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ct-accent);
    margin: 0 0 14px;
    padding: 4px 14px;
    border: 1.5px solid var(--ct-accent);
    border-radius: 100px;
    opacity: 0.75;
  }

  .ct-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    color: var(--ct-heading);
    margin: 0 0 10px;
    line-height: 1.2;
  }

  .ct-subheading {
    font-size: 16px;
    color: var(--ct-text);
    opacity: 0.7;
    margin: 0;
    line-height: 1.6;
  }

  /* Table wrapper — horizontal scroll on mobile */
  .ct-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 16px;
    border: 1px solid var(--ct-border);
  }

  .ct-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 540px;
    background: var(--ct-bg);
    border-radius: 16px;
    overflow: hidden;
  }

  /* Tier header row */
  .ct-tier-row th { border-bottom: 1px solid var(--ct-border); }

  .ct-feature-label-head {
    width: 36%;
    padding: 24px 20px;
    text-align: left;
    font-size: 12px;
    font-weight: 600;
    color: var(--ct-text);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ct-tier-head {
    width: 21.33%;
    text-align: center;
    padding: 28px 16px 24px;
    position: relative;
    vertical-align: top;
  }

  .ct-tier-head--popular {
    background-color: var(--ct-popular-bg);
  }

  .ct-popular-badge {
    display: inline-block;
    background: var(--ct-accent);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: 10px;
  }

  .ct-tier-name {
    font-size: 17px;
    font-weight: 700;
    color: var(--ct-heading);
    line-height: 1.2;
  }

  .ct-tier-head--popular .ct-tier-name {
    color: var(--ct-popular-text);
  }

  .ct-tier-price {
    font-size: 14px;
    color: var(--ct-text);
    opacity: 0.65;
    margin: 4px 0 16px;
  }

  .ct-tier-head--popular .ct-tier-price {
    color: var(--ct-popular-text);
    opacity: 0.75;
  }

  /* CTA button */
  .ct-cta-btn {
    display: inline-block;
    padding: 9px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    border: 1.5px solid var(--ct-accent);
    color: var(--ct-accent);
    background: transparent;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .ct-cta-btn:hover {
    background: var(--ct-accent);
    color: #fff;
  }

  .ct-cta-btn--popular {
    background: var(--ct-accent);
    color: #fff;
    border-color: var(--ct-accent);
  }

  .ct-cta-btn--popular:hover {
    opacity: 0.88;
  }

  /* Feature rows */
  .ct-row { border-bottom: 1px solid var(--ct-border); }
  .ct-row:last-child { border-bottom: none; }

  .ct-row:nth-child(even) { background: rgba(0,0,0,0.018); }

  .ct-feature-label {
    padding: 16px 20px;
    font-size: 14px;
    color: var(--ct-text);
    font-weight: 500;
    text-align: left;
  }

  .ct-feature-note {
    display: block;
    font-size: 11px;
    opacity: 0.55;
    font-weight: 400;
    margin-top: 2px;
  }

  .ct-cell {
    text-align: center;
    padding: 16px 12px;
    vertical-align: middle;
  }

  .ct-cell--popular { background-color: color-mix(in srgb, var(--ct-popular-bg) 30%, transparent); }

  .ct-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ct-yes);
  }

  .ct-cross {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ct-no);
    opacity: 0.45;
  }

  .ct-value {
    font-size: 13px;
    color: var(--ct-text);
    font-weight: 500;
  }

  @media screen and (max-width: 768px) {
    .ct-heading { font-size: calc({{ section.settings.heading_size }}px * 0.82); }
    .ct-table-wrap { border-radius: 12px; }
    .ct-feature-label-head,
    .ct-feature-label { padding-left: 14px; }
  }
</style>

{% schema %}
{
  "name": "Comparison Table",
  "tag": "section",
  "class": "ct-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small pill label above the heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find the right plan"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Compare features across all tiers."
    },
    {
      "type": "header",
      "content": "Tier 1"
    },
    {
      "type": "text",
      "id": "tier1_name",
      "label": "Tier name",
      "default": "Starter"
    },
    {
      "type": "text",
      "id": "tier1_price",
      "label": "Price / subtitle",
      "default": "Free"
    },
    {
      "type": "text",
      "id": "tier1_cta_text",
      "label": "CTA button text",
      "default": "Get started"
    },
    {
      "type": "url",
      "id": "tier1_cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Tier 2"
    },
    {
      "type": "text",
      "id": "tier2_name",
      "label": "Tier name",
      "default": "Pro"
    },
    {
      "type": "text",
      "id": "tier2_price",
      "label": "Price / subtitle",
      "default": "₹999/mo"
    },
    {
      "type": "text",
      "id": "tier2_cta_text",
      "label": "CTA button text",
      "default": "Buy now"
    },
    {
      "type": "url",
      "id": "tier2_cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Tier 3"
    },
    {
      "type": "text",
      "id": "tier3_name",
      "label": "Tier name",
      "default": "Enterprise"
    },
    {
      "type": "text",
      "id": "tier3_price",
      "label": "Price / subtitle",
      "default": "Custom"
    },
    {
      "type": "text",
      "id": "tier3_cta_text",
      "label": "CTA button text",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "tier3_cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Popular tier"
    },
    {
      "type": "select",
      "id": "popular_tier",
      "label": "Highlight as popular",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "1", "label": "Tier 1" },
        { "value": "2", "label": "Tier 2" },
        { "value": "3", "label": "Tier 3" }
      ],
      "default": "2"
    },
    {
      "type": "text",
      "id": "popular_label",
      "label": "Popular badge text",
      "default": "Most Popular"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 52,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border / divider color",
      "default": "#e8e8e8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#5c9bdd"
    },
    {
      "type": "color",
      "id": "check_color",
      "label": "Checkmark color",
      "default": "#22c55e"
    },
    {
      "type": "color",
      "id": "cross_color",
      "label": "Cross color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "popular_bg",
      "label": "Popular column background",
      "default": "#f0f6ff"
    },
    {
      "type": "color",
      "id": "popular_text_color",
      "label": "Popular column text color",
      "default": "#1a2e4a"
    }
  ],
  "blocks": [
    {
      "type": "feature_row",
      "name": "Feature row",
      "settings": [
        {
          "type": "text",
          "id": "feature_name",
          "label": "Feature name",
          "default": "Feature name"
        },
        {
          "type": "text",
          "id": "feature_note",
          "label": "Note (optional)",
          "info": "Small subtext below the feature name"
        },
        {
          "type": "select",
          "id": "tier1_value",
          "label": "Tier 1 value",
          "options": [
            { "value": "yes", "label": "✓ Yes (checkmark)" },
            { "value": "no",  "label": "✗ No (cross)" },
            { "value": "custom", "label": "Custom text" }
          ],
          "default": "no"
        },
        {
          "type": "select",
          "id": "tier2_value",
          "label": "Tier 2 value",
          "options": [
            { "value": "yes", "label": "✓ Yes (checkmark)" },
            { "value": "no",  "label": "✗ No (cross)" },
            { "value": "custom", "label": "Custom text" }
          ],
          "default": "yes"
        },
        {
          "type": "select",
          "id": "tier3_value",
          "label": "Tier 3 value",
          "options": [
            { "value": "yes", "label": "✓ Yes (checkmark)" },
            { "value": "no",  "label": "✗ No (cross)" },
            { "value": "custom", "label": "Custom text" }
          ],
          "default": "yes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        { "type": "feature_row", "settings": { "feature_name": "Free shipping", "tier1_value": "no", "tier2_value": "yes", "tier3_value": "yes" } },
        { "type": "feature_row", "settings": { "feature_name": "Priority support", "tier1_value": "no", "tier2_value": "yes", "tier3_value": "yes" } },
        { "type": "feature_row", "settings": { "feature_name": "Dedicated account manager", "tier1_value": "no", "tier2_value": "no", "tier3_value": "yes" } },
        { "type": "feature_row", "settings": { "feature_name": "Custom packaging", "tier1_value": "no", "tier2_value": "no", "tier3_value": "yes" } },
        { "type": "feature_row", "settings": { "feature_name": "Early access to new products", "tier1_value": "no", "tier2_value": "yes", "tier3_value": "yes" } },
        { "type": "feature_row", "settings": { "feature_name": "30-day free returns", "tier1_value": "yes", "tier2_value": "yes", "tier3_value": "yes" } }
      ]
    }
  ]
}
{% endschema %}
