{% if section.blocks.size > 0 %}
<div class="announcement-bar full-width color-{{ section.settings.color_scheme }}{% if section.settings.marquee_mode %} ik-marquee-bar{% endif %}" id="ikAnnBar" data-interval="{{ section.settings.slide_time | times: 1000 }}" data-marquee="{{ section.settings.marquee_mode }}">

  {% if section.settings.marquee_mode %}
    <div class="ik-marquee-track">
      <div class="ik-marquee-inner" style="--ik-mq-dur: {{ section.settings.marquee_speed }}s;">
        {% for block in section.blocks %}
          <span class="ik-marquee-item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}<span class="ik-marquee-icon" aria-hidden="true">{{ block.settings.icon }}</span>{% endif %}
            {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{{ block.settings.text }}</a>{% else %}{{ block.settings.text }}{% endif %}
            <span class="ik-marquee-sep" aria-hidden="true">•</span>
          </span>
        {% endfor %}
        {% for block in section.blocks %}
          <span class="ik-marquee-item" aria-hidden="true">
            {% if block.settings.icon != blank %}<span class="ik-marquee-icon" aria-hidden="true">{{ block.settings.icon }}</span>{% endif %}
            {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{{ block.settings.text }}</a>{% else %}{{ block.settings.text }}{% endif %}
            <span class="ik-marquee-sep" aria-hidden="true">•</span>
          </span>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <div class="announcement-slider">
      {% for block in section.blocks %}
        <div class="announcement-slide" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}<span class="ik-ann-icon" aria-hidden="true">{{ block.settings.icon }}</span> {% endif %}
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}">
          {% endif %}
            <span>{{ block.settings.text }}</span>
          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_arrows %}
    <button class="announcement-prev">‹</button>
    <button class="announcement-next">›</button>
    {% endif %}
  {% endif %}

  {% if section.settings.show_close %}
    <button class="ik-ann-close" id="ikAnnClose" aria-label="Close announcement">×</button>
  {% endif %}

</div>
{% endif %}

<style>
.announcement-bar {
  background-color: var(--color-background);
  color: var(--color-foreground);
  font-size: {{ section.settings.font_size }}px;
  font-weight: {% if section.settings.font_bold %}700{% else %}400{% endif %};
  font-style: {% if section.settings.font_italic %}italic{% else %}normal{% endif %};
  text-align: center;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  overflow: hidden;
  transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  z-index: 1002;
}

.announcement-bar.scrolled {
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
}

.announcement-slider {
  display: flex;
  transition: transform 0.5s ease;
}

.announcement-slide {
  min-width: 100%;
  padding: 10px 20px;
}

.announcement-slide a {
  color: inherit;
  text-decoration: none;
}

.announcement-prev,
.announcement-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  color: var(--color-foreground);
  border: none;
  font-size: 18px;
  cursor: pointer;
  transition: color 0.3s ease, opacity 0.3s ease;
}

.announcement-prev:hover,
.announcement-next:hover {
  opacity: 0.7;
}

.announcement-prev { left: 10px; }
.announcement-next { right: 10px; }

/* ============================================================
   Phase 5: Announcement Bar Upgrades
   ============================================================ */

/* Emoji icon in slide mode */
.ik-ann-icon { margin-right: 5px; }

/* Marquee / ticker mode */
.ik-marquee-bar { overflow: hidden; }
.ik-marquee-track { overflow: hidden; width: 100%; }
.ik-marquee-inner {
  display: inline-flex;
  white-space: nowrap;
  animation: ikMarquee var(--ik-mq-dur, 30s) linear infinite;
  will-change: transform;
}
.ik-marquee-inner:hover { animation-play-state: paused; }
@keyframes ikMarquee {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.ik-marquee-item {
  display: inline-flex;
  align-items: center;
  padding: 0 24px;
  font-size: inherit;
  font-weight: inherit;
}
.ik-marquee-item a { color: inherit; text-decoration: none; }
.ik-marquee-item a:hover { text-decoration: underline; }
.ik-marquee-icon { margin-right: 7px; }
.ik-marquee-sep { margin: 0 4px; opacity: 0.35; }

@media (prefers-reduced-motion: reduce) {
  .ik-marquee-inner { animation: none; }
}

/* Close button */
.ik-ann-close {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: inherit;
  font-size: 20px;
  line-height: 1;
  padding: 0 4px;
  cursor: pointer;
  opacity: 0.55;
  transition: opacity 0.2s;
  z-index: 2;
}
.ik-ann-close:hover { opacity: 1; }
</style>

<script>
(function() {
  function initAnnouncementBar(sectionEl) {
    var bar = (sectionEl || document).querySelector('.announcement-bar');
    if (!bar) return;

    var slides = bar.querySelectorAll('.announcement-slide');
    var slider = bar.querySelector('.announcement-slider');
    var interval = parseInt(bar.dataset.interval);
    var header = document.querySelector('.header-sticky');
    var index = 0;
    var isMarquee = bar.dataset.marquee === 'true';

    /* Close button */
    var annCloseBtn = document.getElementById('ikAnnClose');
    if (annCloseBtn) {
      annCloseBtn.addEventListener('click', function () {
        bar.style.transition = 'opacity 0.3s ease, max-height 0.4s ease';
        bar.style.opacity = '0';
        bar.style.maxHeight = bar.offsetHeight + 'px';
        setTimeout(function () {
          bar.style.maxHeight = '0';
          bar.style.overflow = 'hidden';
        }, 10);
        setTimeout(function () {
          bar.style.display = 'none';
          document.documentElement.style.setProperty('--announcement-bar-height', '0px');
        }, 400);
      });
    }

    /* In marquee mode, skip interval / slider logic */
    if (isMarquee) {
      updateAnnouncementHeight();
      window.addEventListener('resize', updateAnnouncementHeight);
      window.addEventListener('scroll', function () {
        if (window.scrollY > 50) {
          bar.classList.add('scrolled');
          if (header) header.classList.add('scrolled');
        } else {
          bar.classList.remove('scrolled');
          if (header) header.classList.remove('scrolled');
        }
      });
      return;
    }

    function updateAnnouncementHeight() {
      var barHeight = bar.offsetHeight;
      document.documentElement.style.setProperty('--announcement-bar-height', barHeight + 'px');
    }
    updateAnnouncementHeight();
    window.addEventListener('resize', updateAnnouncementHeight);

    window.addEventListener('scroll', function() {
      if (window.scrollY > 50) {
        bar.classList.add('scrolled');
        if (header) header.classList.add('scrolled');
      } else {
        bar.classList.remove('scrolled');
        if (header) header.classList.remove('scrolled');
      }
    });

    function showSlide(i) {
      slider.style.transform = 'translateX(-' + (i * 100) + '%)';
    }

    function next() {
      index = (index + 1) % slides.length;
      showSlide(index);
    }

    var timer = setInterval(next, interval);

    var prevBtn = bar.querySelector('.announcement-prev');
    var nextBtn = bar.querySelector('.announcement-next');

    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        clearInterval(timer);
        index = (index - 1 + slides.length) % slides.length;
        showSlide(index);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        clearInterval(timer);
        next();
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    initAnnouncementBar(document);
  });

  document.addEventListener('shopify:section:load', function(e) {
    initAnnouncementBar(e.target);
  });
})();
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
     {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "slide_time",
      "label": "Slide change (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "marquee_mode",
      "label": "Marquee / ticker mode",
      "default": false,
      "info": "All messages scroll continuously as a horizontal ticker"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Duration for one full scroll — lower = faster"
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show close / dismiss button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": false
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "checkbox",
      "id": "font_bold",
      "label": "Bold text",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "font_italic",
      "label": "Italic text",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "info": "Optional emoji shown before the text, e.g. 🚚"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Announcement text",
          "default": "Free shipping on orders above ₹999"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Free shipping on orders above ₹999" }},
        { "type": "announcement", "settings": { "text": "Republic Day Sale – Flat 20% OFF" }},
        { "type": "announcement", "settings": { "text": "Extra 10% off on prepaid orders" }}
      ]
    }
  ]
}
{% endschema %}